# Discord
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=        # Dev server only — leave blank for global command deployment

# Google Sheets
GOOGLE_SHEET_ID=1qjqnNmgTKkEJ0Ovvrp17Kwf8Pgu_8fkjSgoU_TLTY0I

# Google service account credentials — choose ONE of the two approaches below:

# Option A (preferred for Heroku): full service account JSON as a single env var
# Paste the entire contents of the downloaded .json key file as the value
D2R_GOOGLE_KEY=

# Option B (fallback): separate vars extracted from the JSON
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n

# IMPORTANT: The service account email must be granted Viewer access to the Google Sheet.
# Share the sheet with: d2r-pvp-1v1-bot@d2r-pvp-1v1-bot.iam.gserviceaccount.com

# Redis
REDIS_URL=redis://localhost:6379

# Cache TTLs (seconds)
CACHE_TTL_RULES=3600     # 1 hour — matchups, banned, deathmatches, general rules
CACHE_TTL_LADDER=60      # 1 minute — refreshes frequently as results come in

# Match / ladder settings
MATCH_CADENCE_DAYS=3     # how often players are expected to play
WARNING_THRESHOLD=5      # warnings before auto-removal from ladder
FARMING_CAP_HOURS=24     # cooldown window for repeat opponent pairing
FARMING_CAP_MAX=2        # max times same pairing allowed within window

# Database (Heroku Postgres — set automatically by add-on, or paste connection string)
DATABASE_URL=

# App
NODE_ENV=development
