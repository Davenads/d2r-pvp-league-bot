{
  "name": "d2r-pvp-league-bot",
  "version": "0.1.0",
  "description": "Discord bot for the D2R PvP 1v1 League",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "deploy": "tsx src/deploy-commands.ts",
    "deploy:global": "tsx src/deploy-commands.ts --global",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "heroku-postbuild": "npm run build",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@discordjs/rest": "^2.3.0",
    "@prisma/client": "^5.22.0",
    "discord-api-types": "^0.37.97",
    "discord.js": "^14.0.0",
    "dotenv": "^16.4.5",
    "googleapis": "^140.0.0",
    "ioredis": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "prisma": "^5.22.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": "20.x"
  }
}
